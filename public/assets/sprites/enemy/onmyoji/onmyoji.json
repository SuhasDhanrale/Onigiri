{
  "id": "onmyoji",
  "name": "Onmyoji",
  "type": "support",
  "radius": 14,
  "colors": {
    "ink": "#1b1918",
    "parchment": "#dfd4ba",
    "navy": "#2b3d60",
    "vermilion": "#b84235",
    "jade": "#4a5d23"
  },
  "drawOrder": ["shadow", "magic-circle", "robe", "shoulders", "head", "hat", "charm"],
  "layers": {
    "shadow": {
      "type": "ellipse",
      "rx": 14,
      "ry": 7,
      "fill": "rgba(0,0,0,0.2)"
    },
    "magic-circle": {
      "type": "group",
      "children": [
        { "type": "circle", "r": 45, "fill": "none", "stroke": "#4a5d23", "strokeWidth": 3, "strokeDasharray": "8,8" },
        { "type": "circle", "r": 35, "fill": "rgba(74,93,35,0.2)" },
        { "type": "polygon", "points": "0,-35 12,35 -36,-12 36,-12 -12,35", "fill": "none", "stroke": "#4a5d23", "strokeWidth": 2, "opacity": 0.9 }
      ]
    },
    "robe": {
      "type": "path",
      "d": "M-35 10 Q0 -30 35 10 Q45 40 0 25 Q-45 40 -35 10",
      "fill": "#dfd4ba",
      "stroke": "#1b1918",
      "strokeWidth": 3,
      "strokeLinejoin": "round"
    },
    "shoulders": {
      "type": "circle",
      "r": 22,
      "fill": "#2b3d60",
      "stroke": "#1b1918",
      "strokeWidth": 3
    },
    "head": {
      "type": "circle",
      "r": 12,
      "fill": "#dfd4ba",
      "stroke": "#1b1918",
      "strokeWidth": 2
    },
    "hat": {
      "type": "path",
      "d": "M-10 0 L-10 -35 Q0 -42 10 -35 L10 0 Z",
      "fill": "#1b1918",
      "stroke": "#1b1918",
      "strokeWidth": 2,
      "strokeLinejoin": "round"
    },
    "charm": {
      "type": "group",
      "children": [
        { "type": "rect", "x": -5, "y": -60, "w": 10, "h": 20, "fill": "#b84235", "stroke": "#1b1918", "strokeWidth": 1 },
        { "type": "lines", "pairs": [[-3,-55,3,-55], [-2,-50,2,-50], [-3,-45,3,-45]], "stroke": "#1b1918", "strokeWidth": 1 }
      ]
    }
  },
  "animations": {
    "idle": {
      "duration": 0,
      "keyframes": []
    },
    "attack": {
      "duration": 700,
      "easing": "ease-out",
      "keyframes": [
        { "time": 0, "layer": "magic-circle", "rotate": 0, "scale": 0.75, "opacity": 0 },
        { "time": 0.5, "layer": "magic-circle", "rotate": 180, "scale": 1.3, "opacity": 1 },
        { "time": 1, "layer": "magic-circle", "rotate": 360, "scale": 0.75, "opacity": 0 },
        { "time": 0.5, "layer": "charm", "translateY": -20, "scale": 1.5, "opacity": 1 },
        { "time": 1, "layer": "charm", "translateY": 0, "scale": 1, "opacity": 0 }
      ]
    }
  },
  "fallbackType": "support"
}