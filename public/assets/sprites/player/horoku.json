    "vermilion": "#b84235",
    "navy": "#2b3d60",
    "khaki": "#8b8574",
    "gold": "#d4af37",
    "steel": "#a8a29e"
  },
  "drawOrder": ["wheels", "frame", "brackets", "coil", "arm", "payload"],
  "layers": {
    "wheels": {
      "type": "group",
      "children": [
        { "type": "roundRect", "x": -55, "y": -45, "w": 14, "h": 26, "r": 4, "fill": "#1b1918", "stroke": "#a8a29e", "strokeWidth": 2 },
        { "type": "roundRect", "x": -55, "y": 19, "w": 14, "h": 26, "r": 4, "fill": "#1b1918", "stroke": "#a8a29e", "strokeWidth": 2 },
        { "type": "roundRect", "x": 41, "y": -45, "w": 14, "h": 26, "r": 4, "fill": "#1b1918", "stroke": "#a8a29e", "strokeWidth": 2 },
        { "type": "roundRect", "x": 41, "y": 19, "w": 14, "h": 26, "r": 4, "fill": "#1b1918", "stroke": "#a8a29e", "strokeWidth": 2 }
      ]
    },
    "frame": {
      "type": "group",
      "children": [
        { "type": "rect", "x": -34, "y": -40, "w": 12, "h": 80, "fill": "#8b8574", "stroke": "#1b1918", "strokeWidth": 3 },
        { "type": "rect", "x": 22, "y": -40, "w": 12, "h": 80, "fill": "#8b8574", "stroke": "#1b1918", "strokeWidth": 3 },
        { "type": "rect", "x": -34, "y": -30, "w": 68, "h": 16, "fill": "#8b8574", "stroke": "#1b1918", "strokeWidth": 3 },
        { "type": "rect", "x": -34, "y": 14, "w": 68, "h": 16, "fill": "#8b8574", "stroke": "#1b1918", "strokeWidth": 3 }
      ]
    },
    "brackets": {
      "type": "group",
      "children": [
        { "type": "circle", "cx": -28, "cy": -22, "r": 3, "fill": "#1b1918" },
        { "type": "circle", "cx": 28, "cy": -22, "r": 3, "fill": "#1b1918" },
        { "type": "circle", "cx": -28, "cy": 22, "r": 3, "fill": "#1b1918" },
        { "type": "circle", "cx": 28, "cy": 22, "r": 3, "fill": "#1b1918" },
