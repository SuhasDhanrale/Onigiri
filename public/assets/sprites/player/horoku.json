        { "type": "lines", "pairs": [[-3,-52,-3,0], [3,-52,3,0]], "stroke": "#1b1918", "strokeWidth": 1, "opacity": 0.4 },
        { "type": "circle", "cx": 0, "cy": -54, "r": 14, "fill": "#2b3d60", "stroke": "#1b1918", "strokeWidth": 3 },
        { "type": "circle", "cx": 0, "cy": -54, "r": 8, "fill": "#1b1918", "opacity": 0.4 }
      ]
    },
    "payload": {
      "type": "group",
      "attackTranslateY": -48,
      "attackScale": 1.8,
      "attackOpacity": 0,
      "restTranslateY": 4,
      "restScale": 1,
      "restOpacity": 1,
