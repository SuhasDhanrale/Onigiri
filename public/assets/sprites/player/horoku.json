        { "type": "path", "d": "M-5 -3 Q0 0 5 -3", "fill": "none", "stroke": "#b84235", "strokeWidth": 2 },
        { "type": "path", "d": "M0 -9 Q5 -18 10 -13", "fill": "none", "stroke": "#dfd4ba", "strokeWidth": 2, "lineDash": [2, 1] },
        { "type": "circle", "cx": 10, "cy": -13, "r": 3, "fill": "#b84235" },
