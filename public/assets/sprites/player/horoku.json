        { "type": "lines", "pairs": [[-18,-12,-18,12], [-10,-12,-10,12], [0,-12,0,12], [10,-12,10,12], [18,-12,18,12]], "stroke": "#1b1918", "strokeWidth": 2 }
      ]
    },
    "arm": {
      "type": "group",
      "attackScaleY": 0.5,
      "attackTranslateY": -4,
      "restTranslateY": 4,
      "originX": 0,
      "originY": 12,
      "children": [
