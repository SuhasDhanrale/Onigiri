  "animations": {
    "idle": {
      "duration": 0,
      "keyframes": []
    },
    "attack": {
      "duration": 500,
      "easing": "ease-out",
      "keyframes": [
        { "time": 0, "layer": "arm", "scaleY": 1, "translateY": 4 },
        { "time": 0.3, "layer": "arm", "scaleY": 0.5, "translateY": -4 },
        { "time": 1, "layer": "arm", "scaleY": 1, "translateY": 4 },
        { "time": 0, "layer": "payload", "translateY": 4, "scale": 1, "opacity": 1 },
        { "time": 0.3, "layer": "payload", "translateY": -48, "scale": 1.8, "opacity": 0 },
        { "time": 1, "layer": "payload", "translateY": 4, "scale": 1, "opacity": 1 }
      ]
    }
  },
  "fallbackType": "siege"
}
