{
  "id": "cavalry",
  "name": "Takeda Cavalry",
  "type": "shock",
  "radius": 28,
  "colors": {
    "ink": "#1b1918",
    "parchment": "#dfd4ba",
    "vermilion": "#b84235",
    "gold": "#d4af37",
    "steel": "#a8a29e"
  },
  "drawOrder": ["dust", "horse", "rider", "spear"],
  "layers": {
    "dust": {
      "type": "group",
      "children": [
        { "type": "circle", "cx": -20, "cy": 40, "r": 15, "fill": "#dfd4ba", "opacity": 0.4 },
        { "type": "circle", "cx": 20, "cy": 40, "r": 20, "fill": "#dfd4ba", "opacity": 0.3 },
        { "type": "circle", "cx": 0, "cy": 50, "r": 18, "fill": "#dfd4ba", "opacity": 0.5 }
      ]
    },
    "horse": {
      "type": "group",
      "attackTranslateY": -8,
      "children": [
        { "type": "ellipse", "cx": 0, "cy": -35, "rx": 16, "ry": 30, "fill": "#1b1918", "stroke": "#a8a29e", "strokeWidth": 2 },
        { "type": "polygon", "points": "-10,-50 -15,-60 -5,-52", "fill": "#1b1918" },
        { "type": "polygon", "points": "10,-50 15,-60 5,-52", "fill": "#1b1918" },
        { "type": "line", "x1": 0, "y1": -55, "x2": 0, "y2": -15, "stroke": "#b84235", "strokeWidth": 6, "lineCap": "round", "lineDash": [2, 4] }
      ]
    },
    "rider": {
      "type": "group",
      "children": [
        { "type": "circle", "r": 24, "fill": "#b84235", "stroke": "#1b1918", "strokeWidth": 3 },
        { "type": "path", "d": "M-20 -10 Q0 -30 20 -10", "fill": "none", "stroke": "#d4af37", "strokeWidth": 3, "lineCap": "round" },
        { "type": "circle", "r": 14, "fill": "#1b1918", "stroke": "#d4af37", "strokeWidth": 2 },
        { "type": "path", "d": "M-8 -5 Q0 -15 8 -5", "fill": "none", "stroke": "#d4af37", "strokeWidth": 2 }
      ]
    },
    "spear": {
      "type": "group",
      "attackTranslateY": -16,
      "children": [
        { "type": "line", "x1": 20, "y1": 10, "x2": 20, "y2": -90, "stroke": "#b84235", "strokeWidth": 4, "lineCap": "round" },
        { "type": "polygon", "points": "20,-105 15,-90 25,-90", "fill": "#a8a29e", "stroke": "#1b1918", "strokeWidth": 1 }
      ]
    }
  },
  "animations": {
    "idle": {
      "duration": 0,
      "keyframes": []
    },
    "attack": {
      "duration": 200,
      "easing": "ease-in-out",
      "keyframes": [
        { "time": 0, "layer": "horse", "translateY": 0 },
        { "time": 0.5, "layer": "horse", "translateY": -8 },
        { "time": 1, "layer": "horse", "translateY": 0 },
        { "time": 0, "layer": "spear", "translateY": 0 },
        { "time": 0.5, "layer": "spear", "translateY": -16 },
        { "time": 1, "layer": "spear", "translateY": 0 },
        { "time": 0, "layer": "dust", "opacity": 0 },
        { "time": 0.5, "layer": "dust", "opacity": 1 },
        { "time": 1, "layer": "dust", "opacity": 0 }
      ]
    }
  },
  "fallbackType": "cavalry"
}
